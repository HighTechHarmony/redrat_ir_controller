[Unit]
Description=RedRat IR Controller Service
After=network.target

[Service]
Type=simple
User=scott
WorkingDirectory=/home/scott/redrat_ir_controller
# ExecStart calls the virtualenv Python and the project entrypoint
ExecStart=/home/scott/redrat_ir_controller/.venv/bin/python /home/scott/redrat_ir_controller/main.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
